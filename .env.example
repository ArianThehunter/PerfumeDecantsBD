# =============================================================================
# PerfumeDecantBD — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
POSTGRES_USER=perfume_admin
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=perfumedecantbd
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# -----------------------------------------------------------------------------
# Backend (FastAPI)
# -----------------------------------------------------------------------------
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# Environment
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Frontend (SvelteKit)
# -----------------------------------------------------------------------------
PUBLIC_API_URL=http://localhost:8000/api
PUBLIC_SITE_NAME=PerfumeDecantBD
PUBLIC_SITE_DESCRIPTION=Luxury Perfume E-commerce Platform

# -----------------------------------------------------------------------------
# Email (Placeholder)
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@perfumedecantbd.com
SMTP_PASSWORD=email_password
SMTP_FROM=noreply@perfumedecantbd.com

# -----------------------------------------------------------------------------
# File Storage
# -----------------------------------------------------------------------------
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10
